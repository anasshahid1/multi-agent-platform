# =============================================================================
# Multi-Agent Auto-Scheduling Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- LLM Configuration ---
# Ollama runs natively on the host; Docker containers reach it via host.docker.internal
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:14b

# --- Gmail SMTP (for sending emails) ---
# Enable 2FA on your Google account, then create an App Password:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=your-email@gmail.com

# --- Gmail IMAP (for Mailman agent — reading emails) ---
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-email@gmail.com
IMAP_PASSWORD=your-app-password

# --- Agent Schedules (cron-style) ---
# These are defaults — can be changed from the dashboard at runtime
AITIMES_SCHEDULE_HOUR=8
AITIMES_SCHEDULE_MINUTE=0

MAILMAN_SCHEDULE_HOUR=9
MAILMAN_SCHEDULE_MINUTE=0

WALLSTREET_SCHEDULE_HOUR=16
WALLSTREET_SCHEDULE_MINUTE=30

NEWS_SCHEDULE_HOUR=7
NEWS_SCHEDULE_MINUTE=0

# --- Database ---
DATABASE_PATH=/app/data/platform.db

# --- System Thresholds ---
CPU_ALERT_THRESHOLD=90
RAM_ALERT_THRESHOLD=90
DISK_ALERT_THRESHOLD=90

# --- LLM Scheduling ---
LLM_REQUEST_TIMEOUT=300
LLM_MAX_QUEUE_SIZE=10
